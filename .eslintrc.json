{
  "env": {
    "node":  true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType":  "commonjs"
  },
  "rules": {
    "no-console":        "warn",
    "no-unused-vars":    "error",
    "no-undef":          "error",
    "prefer-const":      "warn",
    "eqeqeq":            "error"
  }
}
